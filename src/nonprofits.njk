{% block scripts %}
<script>
/**
 * Nonprofit Search & Filter Module
 * Handles search, category filtering, and sorting
 */
const NonprofitFilter = {
    // State
    currentCategory: 'all',
    currentSearch: '',
    currentSort: 'alphabetical',
    isExpanded: true, // Always show all cards with new filter

    // DOM Elements
    elements: {
        grid: null,
        searchInput: null,
        categorySelect: null,
        sortSelect: null,
        toggleBtn: null,
        btnText: null,
        noResults: null,
        showMoreWrapper: null
    },

    /**
     * Initialize the filter module
     */
    init: function() {
        // Cache DOM elements
        this.elements.grid = document.getElementById('nonprofits-grid');
        this.elements.searchInput = document.getElementById('nonprofit-search');
        this.elements.categorySelect = document.getElementById('category-filter');
        this.elements.sortSelect = document.getElementById('sort-filter');
        this.elements.toggleBtn = document.getElementById('toggle-nonprofits');
        this.elements.btnText = this.elements.toggleBtn?.querySelector('.btn-text');
        this.elements.noResults = document.getElementById('no-results');
        this.elements.showMoreWrapper = document.getElementById('show-more-wrapper');

        // Store original card data for sorting
        this.storeCardData();

        // Bind events
        this.bindEvents();

        // Show all cards initially and apply default sort
        this.showAllCards();
        this.applyFilters();

        // Hide View More button (all cards shown with new filter)
        if (this.elements.showMoreWrapper) {
            this.elements.showMoreWrapper.style.display = 'none';
        }
    },

    /**
     * Store card data for sorting
     */
    storeCardData: function() {
        const cards = this.elements.grid.querySelectorAll('.nonprofit-card-item');
        cards.forEach((card) => {
            const titleEl = card.querySelector('.causes-one__title');
            const title = titleEl ? titleEl.textContent.trim() : '';
            card.dataset.title = title;
            // Use nonprofit-id as a proxy for "most recent" (higher ID = more recent)
            card.dataset.order = card.dataset.nonprofitId || '0';
        });
    },

    /**
     * Show all cards (remove hidden state)
     */
    showAllCards: function() {
        const cards = this.elements.grid.querySelectorAll('.nonprofit-card-item');
        cards.forEach(card => {
            card.classList.remove('nonprofit-hidden');
            card.style.display = '';
        });
    },

    /**
     * Bind events for search, filter, and sort
     */
    bindEvents: function() {
        const self = this;

        // Search input - debounced
        if (this.elements.searchInput) {
            let searchTimeout;
            this.elements.searchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(function() {
                    self.currentSearch = self.elements.searchInput.value.toLowerCase().trim();
                    self.applyFilters();
                }, 200);
            });
        }

        // Category dropdown
        if (this.elements.categorySelect) {
            this.elements.categorySelect.addEventListener('change', function() {
                self.currentCategory = this.value;
                self.applyFilters();
            });
        }

        // Sort dropdown
        if (this.elements.sortSelect) {
            this.elements.sortSelect.addEventListener('change', function() {
                self.currentSort = this.value;
                self.applyFilters();
            });
        }

        // Toggle button (View More/Less) - keep for compatibility
        if (this.elements.toggleBtn) {
            this.elements.toggleBtn.addEventListener('click', function() {
                self.toggleExpand();
            });
        }
    },

    /**
     * Apply all filters (search, category, sort)
     */
    applyFilters: function() {
        const cards = Array.from(this.elements.grid.querySelectorAll('.nonprofit-card-item'));
        let visibleCount = 0;

        // First, filter cards
        cards.forEach(card => {
            const cardCategory = card.dataset.category;
            const cardTitle = card.dataset.title.toLowerCase();
            const cardDescription = card.querySelector('.causes-one__text')?.textContent.toLowerCase() || '';

            // Category match
            const categoryMatch = this.currentCategory === 'all' || cardCategory === this.currentCategory;

            // Search match (title or description)
            const searchMatch = this.currentSearch === '' ||
                cardTitle.includes(this.currentSearch) ||
                cardDescription.includes(this.currentSearch);

            if (categoryMatch && searchMatch) {
                card.style.display = '';
                card.classList.remove('nonprofit-hidden');
                card.classList.add('nonprofit-visible');
                visibleCount++;
            } else {
                card.style.display = 'none';
                card.classList.add('nonprofit-hidden');
                card.classList.remove('nonprofit-visible');
            }
        });

        // Then, sort visible cards
        this.sortCards();

        // Show/hide no results message
        this.elements.noResults.style.display = visibleCount === 0 ? 'block' : 'none';
        this.elements.grid.style.display = visibleCount === 0 ? 'none' : '';

        // Re-initialize WOW animations
        if (typeof WOW !== 'undefined') {
            new WOW().init();
        }
    },

    /**
     * Sort cards based on current sort option
     */
    sortCards: function() {
        const grid = this.elements.grid;
        const cards = Array.from(grid.querySelectorAll('.nonprofit-card-item'));

        cards.sort((a, b) => {
            switch (this.currentSort) {
                case 'alphabetical':
                    return a.dataset.title.localeCompare(b.dataset.title);
                case 'reverse-alphabetical':
                    return b.dataset.title.localeCompare(a.dataset.title);
                case 'recent':
                    return parseInt(b.dataset.order) - parseInt(a.dataset.order);
                default:
                    return 0;
            }
        });

        // Re-append cards in sorted order
        cards.forEach(card => grid.appendChild(card));
    },

    /**
     * Toggle expand/collapse for "View More" functionality
     */
    toggleExpand: function() {
        this.isExpanded = !this.isExpanded;

        // Update button text and aria-expanded
        if (this.isExpanded) {
            this.elements.btnText.textContent = 'View Less';
            this.elements.toggleBtn.setAttribute('aria-expanded', 'true');
        } else {
            this.elements.btnText.textContent = 'View More';
            this.elements.toggleBtn.setAttribute('aria-expanded', 'false');

            // Scroll back to grid
            document.getElementById('nonprofits-grid').scrollIntoView({
                behavior: 'smooth',
                block: 'start'
            });
        }

        this.applyFilters();

        // Re-initialize WOW animations
        if (this.isExpanded && typeof WOW !== 'undefined') {
            new WOW().init();
        }
    }
};

// Initialize on DOM ready
document.addEventListener('DOMContentLoaded', function() {
    NonprofitFilter.init();
});
</script>
{% endblock %}
