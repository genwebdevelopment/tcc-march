            <button id="toggle-nonprofits" class="thm-btn nonprofits-show-more__btn" aria-expanded="false" aria-controls="nonprofits-grid">
                <span class="btn-text">View More</span>
            </button>
        </div>
    </div>
</section>
<!--Donation End-->

<!--CTA Section Start-->

<!--CTA Section End-->

{% block scripts %}
<script>
/**
 * Nonprofit Filter Module
 * Handles category filtering with support for future AJAX integration
 *
 * FUTURE AJAX INTEGRATION:
 * - Set NonprofitFilter.useAjax = true to enable AJAX mode
 * - Configure NonprofitFilter.ajaxUrl with your API endpoint
 * - The fetchNonprofits() method will make AJAX calls instead of client-side filtering
 */
const NonprofitFilter = {
    // Configuration - Change these for AJAX mode
    useAjax: false,  // Set to true when ready to use AJAX
    ajaxUrl: '/api/nonprofits',  // Your API endpoint

    // State
    currentCategory: 'all',
    isExpanded: false,
    initialVisibleCount: 8,

    // DOM Elements
    elements: {
        grid: null,
        filterButtons: null,
        toggleBtn: null,
        btnText: null,
        loading: null,
        noResults: null,
        showMoreWrapper: null
    },

    /**
     * Initialize the filter module
     */
    init: function() {
        // Cache DOM elements
        this.elements.grid = document.getElementById('nonprofits-grid');
        this.elements.filterButtons = document.querySelectorAll('.nonprofit-filter__btn');
        this.elements.toggleBtn = document.getElementById('toggle-nonprofits');
        this.elements.btnText = this.elements.toggleBtn?.querySelector('.btn-text');
        this.elements.loading = document.getElementById('filter-loading');
        this.elements.noResults = document.getElementById('no-results');
        this.elements.showMoreWrapper = document.getElementById('show-more-wrapper');

        // Bind events
        this.bindEvents();

        // Store original hidden state for "all" category
        this.storeOriginalState();
    },

    /**
     * Store the original hidden state of cards
     */
    storeOriginalState: function() {
        const cards = this.elements.grid.querySelectorAll('.nonprofit-card-item');
        cards.forEach((card, index) => {
            card.dataset.originalHidden = index >= this.initialVisibleCount ? 'true' : 'false';
        });
    },

    /**
     * Bind click events to filter buttons and toggle button
     */
    bindEvents: function() {
        const self = this;

        // Filter button clicks
        this.elements.filterButtons.forEach(function(btn) {
            btn.addEventListener('click', function() {
                const category = this.dataset.category;
                const categoryId = this.dataset.categoryId;
                self.filterByCategory(category, categoryId);

                // Update active state and aria-pressed
                self.elements.filterButtons.forEach(b => {
                    b.classList.remove('active');
                    b.setAttribute('aria-pressed', 'false');
                });
                this.classList.add('active');
                this.setAttribute('aria-pressed', 'true');
            });
        });

        // Toggle button click
        if (this.elements.toggleBtn) {
            this.elements.toggleBtn.addEventListener('click', function() {
                self.toggleExpand();
            });
        }
    },

    /**
     * Filter nonprofits by category
     * @param {string} category - Category slug
     * @param {string} categoryId - Category ID for AJAX calls
     */
    filterByCategory: function(category, categoryId) {
        this.currentCategory = category;

        if (this.useAjax) {
            // AJAX MODE: Fetch from server
            this.fetchNonprofits(category, categoryId);
        } else {
            // CLIENT-SIDE MODE: Filter existing cards
            this.filterCardsClientSide(category);
        }
    },

    /**
     * Client-side filtering of nonprofit cards
     * @param {string} category - Category to filter by
     */
    filterCardsClientSide: function(category) {
        const cards = this.elements.grid.querySelectorAll('.nonprofit-card-item');
        let visibleCount = 0;
        let totalMatching = 0;

        cards.forEach((card, index) => {
            const cardCategory = card.dataset.category;
            const isMatch = category === 'all' || cardCategory === category;

            if (isMatch) {
                totalMatching++;

                if (category === 'all') {
                    // For "all", respect original hidden state unless expanded
                    if (card.dataset.originalHidden === 'true' && !this.isExpanded) {
                        card.style.display = 'none';
                        card.classList.add('nonprofit-hidden');
                        card.classList.remove('nonprofit-visible');
                    } else {
                        card.style.display = '';
                        card.classList.remove('nonprofit-hidden');
                        card.classList.add('nonprofit-visible');
                        visibleCount++;
                    }
                } else {
                    // For specific category, show all matching
                    card.style.display = '';
                    card.classList.remove('nonprofit-hidden');
                    card.classList.add('nonprofit-visible');
                    visibleCount++;
                }
            } else {
                card.style.display = 'none';
                card.classList.add('nonprofit-hidden');
                card.classList.remove('nonprofit-visible');
            }
        });

        // Show/hide no results message
        this.elements.noResults.style.display = visibleCount === 0 ? 'block' : 'none';
        this.elements.grid.style.display = visibleCount === 0 ? 'none' : '';

        // Show/hide "View More" button based on category
        if (category === 'all') {
            const hiddenInAll = Array.from(cards).filter(c => c.dataset.originalHidden === 'true').length;
            this.elements.showMoreWrapper.style.display = hiddenInAll > 0 ? '' : 'none';
        } else {
            // Hide "View More" when filtering by specific category
            this.elements.showMoreWrapper.style.display = 'none';
        }

        // Re-initialize WOW animations
        if (typeof WOW !== 'undefined') {
            new WOW().init();
        }
    },

    /**
     * AJAX: Fetch nonprofits from server
     * @param {string} category - Category slug
     * @param {string} categoryId - Category ID
     */
    fetchNonprofits: function(category, categoryId) {
        const self = this;

        // Show loading
        this.showLoading(true);
        this.elements.grid.style.opacity = '0.5';

        // Build request URL
        const url = category === 'all'
            ? this.ajaxUrl
            : `${this.ajaxUrl}?category=${categoryId}`;

        // Make AJAX request
        fetch(url, {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            self.renderNonprofits(data.nonprofits || data);
            self.showLoading(false);
            self.elements.grid.style.opacity = '1';
        })
        .catch(error => {
            console.error('Error fetching nonprofits:', error);
            self.showLoading(false);
            self.elements.grid.style.opacity = '1';
            // Fallback to client-side filtering on error
            self.filterCardsClientSide(category);
        });
    },

    /**
     * Render nonprofits from AJAX response
     * @param {Array} nonprofits - Array of nonprofit objects
     */
    renderNonprofits: function(nonprofits) {
        if (!nonprofits || nonprofits.length === 0) {
            this.elements.grid.innerHTML = '';
            this.elements.noResults.style.display = 'block';
            this.elements.grid.style.display = 'none';
            this.elements.showMoreWrapper.style.display = 'none';
            return;
        }

        this.elements.noResults.style.display = 'none';
        this.elements.grid.style.display = '';
        this.elements.showMoreWrapper.style.display = 'none'; // Hide when using AJAX

        // Generate HTML for each nonprofit
        const html = nonprofits.map((np, index) => this.generateCardHTML(np, index)).join('');
        this.elements.grid.innerHTML = html;

        // Re-initialize WOW animations
        if (typeof WOW !== 'undefined') {
            new WOW().init();
        }
    },

    /**
     * Generate HTML for a single nonprofit card
     * @param {Object} nonprofit - Nonprofit data object
     * @param {number} index - Index for animation delay
     * @returns {string} HTML string
     */
    generateCardHTML: function(nonprofit, index) {
        const delay = ((index % 6) + 1) * 100;

        return `
            <div class="col-xl-3 col-lg-6 col-md-6 wow fadeInUp nonprofit-card-item"
                 data-wow-delay="${delay}ms"
                 data-category="${nonprofit.category_slug || ''}"
                 data-nonprofit-id="${nonprofit.id || ''}">
                <div class="causes-one__single">
                    <div class="causes-one__img">
                        <img src="${nonprofit.image || '/assets/images/resources/causes-1-1.jpg'}" alt="${nonprofit.title || ''}">
                        <div class="causes-one__cat" data-category="${nonprofit.category_slug || ''}">
                            <p>${nonprofit.category || ''}</p>
                        </div>
                    </div>
                    <div class="causes-one__content">
                        <h3 class="causes-one__title">
                            <a href="${nonprofit.url || '#'}">${nonprofit.title || ''}</a>
                        </h3>
                        <p class="causes-one__text">${nonprofit.description || ''}</p>
                    </div>
                </div>
            </div>
        `;
    },

    /**
     * Toggle expand/collapse for "View More" functionality
     */
    toggleExpand: function() {
        this.isExpanded = !this.isExpanded;

        if (this.currentCategory === 'all') {
            const cards = this.elements.grid.querySelectorAll('.nonprofit-card-item');

            cards.forEach(card => {
                if (card.dataset.originalHidden === 'true') {
                    if (this.isExpanded) {
                        card.style.display = '';
                        card.classList.remove('nonprofit-hidden');
                        card.classList.add('nonprofit-visible');
                    } else {
                        card.style.display = 'none';
                        card.classList.add('nonprofit-hidden');
                        card.classList.remove('nonprofit-visible');
                    }
                }
            });
        }

        // Update button text and aria-expanded
        if (this.isExpanded) {
            this.elements.btnText.textContent = 'View Less';
            this.elements.toggleBtn.setAttribute('aria-expanded', 'true');
        } else {
            this.elements.btnText.textContent = 'View More';
            this.elements.toggleBtn.setAttribute('aria-expanded', 'false');

            // Scroll back to grid
            document.getElementById('nonprofits-grid').scrollIntoView({
                behavior: 'smooth',
                block: 'start'
            });
        }

        // Re-initialize WOW animations
        if (this.isExpanded && typeof WOW !== 'undefined') {
            new WOW().init();
        }
    },

    /**
     * Show/hide loading indicator
     * @param {boolean} show - Whether to show loading
     */
    showLoading: function(show) {
        if (this.elements.loading) {
            this.elements.loading.style.display = show ? 'flex' : 'none';
        }
    }
};

// Initialize on DOM ready
document.addEventListener('DOMContentLoaded', function() {
    NonprofitFilter.init();
});
</script>
{% endblock %}
