---
layout: base.njk
title: Inspiring Philanthropy
description: >-
  Tin Cup Challenge - One of the most innovative charitable fundraisers in the
  nation. Join us in Teton Valley, Idaho to support local nonprofits.
---
<!--Main Slider Start-->
<section class="main-slider clearfix">
    <div class="main-slider-single">
        <div class="image-layer" style="background-image: url(/assets/images/tin-cup/race-start.jpg);"></div>
        <!-- /.image-layer -->

        <div class="main-slider-shape-1" style="background-image: url(/assets/images/shapes/main-slider-shape-1.jpg);"></div>
        <div class="main-slider-shape-2 float-bob-x">
            <img src="/assets/images/shapes/main-slider-shape-2.png" alt="" />
        </div>

        <div class="container hero-container">
            <div class="row">
                <div class="col-xl-6 col-lg-8">
                    <div class="main-slider__content">
                        <p class="main-slider__sub-title editable">3rd Saturday in July | Driggs City Park</p>
                        <h1 class="main-slider__title editable">Tin Cup Event Day</h1>
                        <p class="main-slider__subtitle editable">Generosity in Action</p>
                        <div class="main-slider__btn-box">
                            <a href="#join-the-fun" class="thm-btn main-slider__btn">Register to Run</a>
                            {% set btnClass = "main-slider__btn" %}
                            {% include "partials/donate-button.njk" %}
