{% block scripts %}
<!-- Hero Text Animation Script -->
<script>
    (function() {
        // Wait for DOM to be ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initHeroAnimation);
        } else {
            initHeroAnimation();
        }

        function initHeroAnimation() {
            // Hide letters initially
            const allLetters = document.querySelectorAll('.hero-letter');
            if (allLetters.length === 0) return;

            allLetters.forEach(letter => letter.classList.add('animate-ready'));

            // Small delay then start animation
            setTimeout(function() {
                const words = document.querySelectorAll('.hero-word');
                let totalDelay = 0;
                const letterDelay = 80; // Delay between each letter (ms)
                const wordDelay = 400; // Extra delay between words (ms)

                words.forEach((word, wordIndex) => {
                    const letters = word.querySelectorAll('.hero-letter');

                    letters.forEach((letter, letterIndex) => {
                        setTimeout(() => {
                            letter.classList.add('visible');
                        }, totalDelay + (letterIndex * letterDelay));
                    });

                    // Update total delay for next word
                    totalDelay += (letters.length * letterDelay) + wordDelay;
                });
            }, 300);
        }
    })();
</script>

<!-- Countdown Timer Script -->
<script>
    (function() {
        // Set event date - 3rd Saturday in July 2026 (July 18, 2026)
        const eventDate = new Date('2026-07-18T09:00:00').getTime();

        function updateCountdown() {
            const now = new Date().getTime();
            const distance = eventDate - now;

            if (distance < 0) {
                document.getElementById('days').textContent = '00';
                document.getElementById('hours').textContent = '00';
                document.getElementById('minutes').textContent = '00';
                document.getElementById('seconds').textContent = '00';
                document.getElementById('days2').textContent = '00';
                document.getElementById('hours2').textContent = '00';
                document.getElementById('minutes2').textContent = '00';
                document.getElementById('seconds2').textContent = '00';
                return;
            }

            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

            document.getElementById('days').textContent = String(days).padStart(2, '0');
            document.getElementById('hours').textContent = String(hours).padStart(2, '0');
            document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
            document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
            document.getElementById('days2').textContent = String(days).padStart(2, '0');
            document.getElementById('hours2').textContent = String(hours).padStart(2, '0');
            document.getElementById('minutes2').textContent = String(minutes).padStart(2, '0');
            document.getElementById('seconds2').textContent = String(seconds).padStart(2, '0');
        }

        // Update immediately and then every second
        updateCountdown();
        setInterval(updateCountdown, 1000);
    })();
</script>

<!-- Stats Number Animation Script -->
<script>
    (function() {
        const animateNumbers = document.querySelectorAll('.animate-number');
        let hasAnimated = false;

        function formatNumber(num) {
            return num.toLocaleString('en-US');
        }

        function quickScramble(element, targetValue, prefix, suffix) {
            const steps = [
                { delay: 150, maxPercent: 0.08 },  // Small numbers, slow
                { delay: 140, maxPercent: 0.15 },
                { delay: 125, maxPercent: 0.25 },
                { delay: 110, maxPercent: 0.35 },
                { delay: 95, maxPercent: 0.45 },
                { delay: 80, maxPercent: 0.55 },   // Getting faster and bigger
                { delay: 70, maxPercent: 0.65 },
                { delay: 60, maxPercent: 0.75 },
                { delay: 50, maxPercent: 0.83 },
                { delay: 40, maxPercent: 0.90 },
                { delay: 35, maxPercent: 0.95 },
                { delay: 30, maxPercent: 0.99 },   // Fast, almost there
            ];
            let stepIndex = 0;

            function showStep() {
                if (stepIndex < steps.length) {
                    const step = steps[stepIndex];
                    const maxVal = Math.floor(targetValue * step.maxPercent);
                    const minVal = Math.floor(maxVal * 0.7);
                    const randomNum = Math.floor(Math.random() * (maxVal - minVal)) + minVal;
                    element.textContent = prefix + formatNumber(randomNum) + (suffix || '');
                    stepIndex++;
                    setTimeout(showStep, step.delay);
                } else {
                    // Show final number
                    element.textContent = prefix + formatNumber(targetValue) + (suffix || '');
                }
            }

            showStep();
        }

        function handleIntersection(entries) {
            entries.forEach(entry => {
                if (entry.isIntersecting && !hasAnimated) {
                    hasAnimated = true;
                    animateNumbers.forEach(element => {
                        const target = parseInt(element.dataset.target);
                        const prefix = element.dataset.prefix || '';
                        const suffix = element.dataset.suffix || '';
                        quickScramble(element, target, prefix, suffix);
                    });
                }
            });
        }

        // Set up Intersection Observer
        const observer = new IntersectionObserver(handleIntersection, {
            threshold: 0.1 // Trigger when 10% of section is visible
        });

        const statsSection = document.querySelector('.stats-section');
        if (statsSection) {
            observer.observe(statsSection);

            // Also check if already visible on page load
            const rect = statsSection.getBoundingClientRect();
            if (rect.top < window.innerHeight && rect.bottom > 0 && !hasAnimated) {
                hasAnimated = true;
                animateNumbers.forEach(element => {
                    const target = parseInt(element.dataset.target);
                    const prefix = element.dataset.prefix || '';
                    const suffix = element.dataset.suffix || '';
                    quickScramble(element, target, prefix, suffix);
                });
            }
        }
    })();
</script>

<!-- Lightbox Script -->
<script>
    (function() {
        const galleryImages = [
            '/assets/images/gallery/community-1.jpg',
            '/assets/images/gallery/community-2.jpg',
            '/assets/images/gallery/community-3.jpg',
            '/assets/images/gallery/community-4.jpg',
            '/assets/images/gallery/community-5.jpg',
            '/assets/images/gallery/community-6.jpg',
            '/assets/images/gallery/community-7.jpg',
            '/assets/images/gallery/community-8.jpg'
        ];

        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');
        const lightboxCounter = document.getElementById('lightbox-counter');
        const closeBtn = document.getElementById('lightbox-close');
        const prevBtn = document.getElementById('lightbox-prev');
        const nextBtn = document.getElementById('lightbox-next');
        let currentIndex = 0;

        function openLightbox(index) {
            currentIndex = index;
            updateLightbox();
            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            lightbox.classList.remove('active');
            document.body.style.overflow = '';
        }

        function updateLightbox() {
            lightboxImg.src = galleryImages[currentIndex];
            lightboxCounter.textContent = (currentIndex + 1) + ' / ' + galleryImages.length;
        }

        function nextImage() {
            currentIndex = (currentIndex + 1) % galleryImages.length;
            updateLightbox();
        }

        function prevImage() {
            currentIndex = (currentIndex - 1 + galleryImages.length) % galleryImages.length;
            updateLightbox();
        }

        // Add click handlers to gallery slides
        document.querySelectorAll('.community-energy__slide').forEach(slide => {
            slide.addEventListener('click', () => {
                const index = parseInt(slide.dataset.index);
                openLightbox(index);
            });
        });

        // Lightbox controls
        closeBtn.addEventListener('click', closeLightbox);
        prevBtn.addEventListener('click', prevImage);
        nextBtn.addEventListener('click', nextImage);

        // Close on background click
        lightbox.addEventListener('click', (e) => {
            if (e.target === lightbox) {
                closeLightbox();
            }
        });

        // Keyboard navigation
        document.addEventListener('keydown', (e) => {
            if (!lightbox.classList.contains('active')) return;
            if (e.key === 'Escape') closeLightbox();
            if (e.key === 'ArrowRight') nextImage();
            if (e.key === 'ArrowLeft') prevImage();
        });
    })();
</script>

<!-- Gallery Carousel Navigation Script -->
<script>
    (function() {
        const track = document.getElementById('gallery-track');
        const prevBtn = document.getElementById('gallery-prev');
        const nextBtn = document.getElementById('gallery-next');
        const slides = document.querySelectorAll('.community-energy__slide');
        const totalSlides = slides.length;
        let currentPosition = 0;

        function getSlideWidth() {
            const width = window.innerWidth;
            if (width <= 767) return 200 + 12; // width + gap
            if (width <= 991) return 250 + 20;
            if (width <= 1200) return 275 + 20;
            return 312 + 20;
        }

        function getVisibleSlides() {
            const slideWidth = getSlideWidth();
            const viewportWidth = window.innerWidth - 100; // account for nav buttons and padding
            return Math.floor(viewportWidth / slideWidth);
        }

        function updateCarousel() {
            const slideWidth = getSlideWidth();
            track.style.transform = `translateX(-${currentPosition * slideWidth}px)`;
        }

        function nextSlide() {
            const visibleSlides = getVisibleSlides();
            const maxPosition = totalSlides - visibleSlides;
            if (currentPosition < maxPosition) {
                currentPosition++;
            } else {
                currentPosition = 0; // Loop back to start
            }
            updateCarousel();
        }

        function prevSlide() {
            const visibleSlides = getVisibleSlides();
            const maxPosition = totalSlides - visibleSlides;
            if (currentPosition > 0) {
                currentPosition--;
            } else {
                currentPosition = maxPosition; // Loop to end
            }
            updateCarousel();
        }

        prevBtn.addEventListener('click', prevSlide);
        nextBtn.addEventListener('click', nextSlide);

        // Reset position on window resize
        window.addEventListener('resize', () => {
            const visibleSlides = getVisibleSlides();
            const maxPosition = totalSlides - visibleSlides;
            if (currentPosition > maxPosition) {
                currentPosition = maxPosition;
            }
            updateCarousel();
        });
    })();
</script>

<!-- Challengers Carousel Infinite Scroll Script -->
<script>
    (function() {
        const track = document.querySelector('.challengers-carousel__track');
        if (!track) return;

        // Remove CSS animation and handle with JavaScript for smoother infinite scroll
        track.style.animation = 'none';

        let scrollPosition = 0;
        let isPaused = false;
        const scrollSpeed = 0.5; // pixels per frame

        // Get the width of the first half of logos (8 logos)
        const logos = track.querySelectorAll('.challengers-carousel__logo');
        const halfwayPoint = logos.length / 2;

        function getHalfWidth() {
            let width = 0;
            for (let i = 0; i < halfwayPoint; i++) {
                width += logos[i].offsetWidth;
            }
            // Add gaps (40px between each logo in the first half)
            width += 40 * (halfwayPoint - 1);
            return width;
        }

        function animate() {
            if (!isPaused) {
                scrollPosition += scrollSpeed;
                const resetPoint = getHalfWidth() + 20; // +20 for the gap after last logo in first set

                // Reset position seamlessly when we've scrolled past the first set
                if (scrollPosition >= resetPoint) {
                    scrollPosition = 0;
                }

                track.style.transform = `translateX(-${scrollPosition}px)`;
            }
            requestAnimationFrame(animate);
        }

        // Start animation
        animate();

        // Pause animation on hover for better UX
        track.addEventListener('mouseenter', () => {
            isPaused = true;
        });

        track.addEventListener('mouseleave', () => {
            isPaused = false;
        });
    })();
</script>
