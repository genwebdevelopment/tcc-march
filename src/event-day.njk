{% block scripts %}
<!-- Event Day Countdown Timer Script -->
<script>
    (function() {
        // Set event date - 3rd Saturday in July 2026 (July 18, 2026)
        const eventDate = new Date('2026-07-18T09:00:00').getTime();

        function updateCountdown() {
            const now = new Date().getTime();
            const distance = eventDate - now;

            if (distance < 0) {
                document.getElementById('days').textContent = '00';
                document.getElementById('hours').textContent = '00';
                document.getElementById('minutes').textContent = '00';
                document.getElementById('seconds').textContent = '00';
                return;
            }

            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

            document.getElementById('days').textContent = String(days).padStart(2, '0');
            document.getElementById('hours').textContent = String(hours).padStart(2, '0');
            document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
            document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
        }

        // Update immediately and then every second
        updateCountdown();
        setInterval(updateCountdown, 1000);
    })();
</script>

<!-- FAQ Accordion Script - Override theme default to allow closing on click -->
<script>
    // Wait for jQuery to be available, then override accordion behavior
    function initAccordionOverride() {
        if (typeof jQuery === 'undefined') {
            setTimeout(initAccordionOverride, 100);
            return;
        }

        jQuery(document).ready(function($) {
            setTimeout(function() {
                $('.faq-page .accrodion-grp').each(function() {
                    var Self = $(this);

                    // Remove ALL existing click handlers from accordion titles
                    Self.find('.accrodion .accrodion-title').off();

                    // Add new click handler that allows closing
                    Self.find('.accrodion .accrodion-title').on('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();

                        var parentAccordion = $(this).parent();
                        var isActive = parentAccordion.hasClass('active');

                        // Close all accordions in this group
                        Self.find('.accrodion').removeClass('active');
                        Self.find('.accrodion .accrodion-content').slideUp();

                        // If it wasn't active, open it. If it was active, it stays closed.
                        if (!isActive) {
                            parentAccordion.addClass('active');
                            parentAccordion.find('.accrodion-content').slideDown();
                        }
                    });
                });
            }, 500);
        });
    }
    initAccordionOverride();
</script>

<!-- Event Day Video Play Script -->
<script>
    (function() {
        const playBtn = document.getElementById('playVideoBtn');
        const overlay = document.getElementById('videoOverlay');
        const iframe = document.getElementById('eventDayVideo');

        if (playBtn && overlay && iframe) {
            playBtn.addEventListener('click', function() {
                // Hide the overlay
                overlay.classList.add('hidden');

                // Start playing the video by updating the src with autoplay
                const currentSrc = iframe.src;
                if (!currentSrc.includes('autoplay=1')) {
                    iframe.src = currentSrc + '&autoplay=1';
                }
            });

            // Also allow clicking anywhere on the overlay
            overlay.addEventListener('click', function() {
                overlay.classList.add('hidden');
                const currentSrc = iframe.src;
                if (!currentSrc.includes('autoplay=1')) {
                    iframe.src = currentSrc + '&autoplay=1';
                }
            });
        }
    })();
</script>
