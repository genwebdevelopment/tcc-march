    {% block head %}{% endblock %}
</head>

<body class="custom-cursor">

    {% if protected %}
    <!-- Password Protection Overlay -->
    <style>
        #password-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #005282 0%, #192a3d 100%);
            z-index: 999999;
            justify-content: center;
            align-items: center;
        }
        #password-overlay::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('/assets/images/tin-cup/race-start.jpg') center/cover no-repeat;
            opacity: 0.15;
        }
        .password-box {
            position: relative;
            background: rgba(255, 255, 255, 0.98);
            padding: 60px 50px;
            border-radius: 20px;
            box-shadow: 0 25px 80px rgba(0, 0, 0, 0.4);
            text-align: center;
            max-width: 420px;
            width: 90%;
            margin: 20px;
        }
        .password-box__logo {
            width: 200px;
            margin-bottom: 35px;
        }
        .password-box__title {
            color: #005282;
            margin-bottom: 8px;
            font-family: 'Oswald', sans-serif;
            font-weight: 600;
            font-size: 28px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .password-box__subtitle {
            color: #6f7775;
            margin-bottom: 30px;
            font-family: 'Manrope', sans-serif;
            font-size: 15px;
            font-weight: 500;
        }
        .password-box__input {
            width: 100%;
            padding: 16px 20px;
            border: 2px solid #ffffff;
            border-radius: 10px;
            font-size: 16px;
            margin-bottom: 15px;
            font-family: 'Manrope', sans-serif;
            transition: border-color 0.3s, box-shadow 0.3s;
            outline: none;
        }
        .password-box__input:focus {
            border-color: #005282;
            box-shadow: 0 0 0 4px rgba(0, 82, 130, 0.1);
        }
        .password-box__error {
            color: #E23F5C;
            margin-bottom: 15px;
            display: none;
            font-family: 'Manrope', sans-serif;
            font-size: 14px;
            font-weight: 600;
        }
        .password-box__btn {
            width: 100%;
            padding: 16px 30px;
            background: #005282;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            font-family: 'Manrope', sans-serif;
            transition: background 0.3s, transform 0.2s;
        }
        .password-box__btn:hover {
            background: #003d61;
            transform: translateY(-2px);
        }
        .password-box__btn:active {
            transform: translateY(0);
        }
        .password-box__footer {
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid #ffffff;
            font-family: 'Manrope', sans-serif;
            font-size: 13px;
            color: #999;
        }
    </style>
    <div id="password-overlay">
        <div class="password-box">
            <img src="/assets/images/brand/tin-cup-logo.svg" alt="Tin Cup Challenge" class="password-box__logo">
            <h2 class="password-box__title">Protected Page</h2>
            <p class="password-box__subtitle">This page is for authorized viewing only.<br>Please enter the password to continue.</p>
            <form id="password-form" onsubmit="return checkPassword(event)">
                <input type="password" id="password-input" placeholder="Enter password" class="password-box__input" autocomplete="off">
                <p id="password-error" class="password-box__error">Incorrect password. Please try again.</p>
                <button type="submit" class="password-box__btn">Unlock Page</button>
            </form>
            <div class="password-box__footer">
                Tin Cup Challenge &bull; Community Foundation of Teton Valley
            </div>
        </div>
    </div>
    <script>
        (function() {
            var correctPassword = 'tin-cup-challenge-design';
            var storageKey = 'tcc_auth';

            if (sessionStorage.getItem(storageKey) === 'true') {
                document.getElementById('password-overlay').style.display = 'none';
            } else {
                document.getElementById('password-overlay').style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }

            window.checkPassword = function(e) {
                e.preventDefault();
                var input = document.getElementById('password-input').value;
                if (input === correctPassword) {
                    sessionStorage.setItem(storageKey, 'true');
                    document.getElementById('password-overlay').style.display = 'none';
                    document.body.style.overflow = '';
                } else {
                    document.getElementById('password-error').style.display = 'block';
                    document.getElementById('password-input').value = '';
                    document.getElementById('password-input').focus();
                }
                return false;
            };

            // Auto-focus the password input
            document.getElementById('password-input').focus();
        })();
    </script>
    {% endif %}

    <!-- Skip to main content link for accessibility -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <div class="custom-cursor__cursor"></div>
    <div class="custom-cursor__cursor-two"></div>

    <div class="preloader">
        <div class="preloader__image"></div>
    </div>
    <!-- /.preloader -->

    <div class="page-wrapper">
        {% include "header.njk" %}

        <div class="stricky-header stricked-menu main-menu">
            <div class="sticky-header__content"></div><!-- /.sticky-header__content -->
        </div><!-- /.stricky-header -->

        <main id="main-content">
        {{ content | safe }}
        </main>

        {% include "cta-banner.njk" %}

        {% include "footer.njk" %}
    </div><!-- /.page-wrapper -->

    {% include "mobile-nav.njk" %}

    <div class="search-popup">
        <div class="search-popup__overlay search-toggler"></div>
        <!-- /.search-popup__overlay -->
        <div class="search-popup__content">
            <form action="#">
                <label for="search" class="sr-only">search here</label><!-- /.sr-only -->
                <input type="text" id="search" placeholder="Search Here..." />
                <button type="submit" aria-label="search submit" class="thm-btn">
                    <i class="icon-magnifying-glass"></i>
                </button>
            </form>
        </div>
        <!-- /.search-popup__content -->
    </div>
    <!-- /.search-popup -->

    <a href="#" data-target="html" class="scroll-to-target scroll-to-top" aria-label="Back to top"><i class="icon-up-arrow" aria-hidden="true"></i></a>

