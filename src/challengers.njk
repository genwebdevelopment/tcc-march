<!-- Intro Section -->
<section class="page-intro" style="padding: 80px 0; background: var(--cftv-burgundy);">
    <div class="container">
        <div class="section-title text-center" style="margin-bottom: 0; padding-bottom: 0;">
            <h2 class="section-title__title editable" style="color: #fff;">Accept the Challenge</h2>
            <p class="editable" style="font-size: 24px; margin: 20px auto 0; color: #fff;">Become a Tin Cup Challenger</p>
