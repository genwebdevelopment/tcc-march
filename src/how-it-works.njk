<!-- Why Tin Cup Matters -->
<section class="about-three why-tin-cup">
    <div class="container">
        <div class="row">
            <div class="col-xl-6">
                <div class="about-three__right">
                    <div class="about-three__img-box wow slideInLeft" data-wow-delay="100ms" data-wow-duration="2500ms">
                        <div class="about-three__img">
                            <img src="/assets/images/why/why-tc.webp" alt="Tin Cup Challenge Community Event" class="editable" />
                        </div>
                        <div class="about-three__img-two">
                            <div class="powered-by" style="background: var(--cftv-navy); border-radius: 12px; padding: 30px; height: 100%; display: flex; flex-direction: column; justify-content: center;">
                                <h3 class="editable" style="font-family: 'Oswald', sans-serif; font-size: 20px; color: #ffffff; margin-bottom: 15px;">Powered by Community</h3>
                                <ul style="list-style: none; padding: 0; margin: 0;">
                                    <li style="margin-bottom: 10px;"><a href="/challengers/" style="color: #ffffff; font-size: 16px; text-decoration: none;"><i class="fa fa-circle" style="color: var(--cftv-gold); margin-right: 8px; font-size: 8px; vertical-align: middle;"></i> Challengers</a></li>
                                    <li style="margin-bottom: 10px;"><span style="color: #ffffff; font-size: 16px;"><i class="fa fa-circle" style="color: var(--cftv-gold); margin-right: 8px; font-size: 8px; vertical-align: middle;"></i> In-Kind Donors</span></li>
                                    <li style="margin-bottom: 10px;"><span style="color: #ffffff; font-size: 16px;"><i class="fa fa-circle" style="color: var(--cftv-gold); margin-right: 8px; font-size: 8px; vertical-align: middle;"></i> Volunteers</span></li>
                                    <li><a href="https://cftetonvalley.org" target="_blank" style="color: #ffffff; font-size: 16px; text-decoration: none;"><i class="fa fa-circle" style="color: var(--cftv-gold); margin-right: 8px; font-size: 8px; vertical-align: middle;"></i> Community Foundation of Teton Valley</a></li>
                                </ul>
                            </div>
                        </div>
                        <div class="about-three__border"></div>
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="about-three__left">
                    <div class="section-title text-left">
                        <span class="section-title__tagline editable">Community Impact</span>
                        <h2 class="section-title__title editable">Why Tin Cup Matters</h2>
                    </div>
                    <p class="about-three__text-1 editable">Tin Cup brings our community together to support local nonprofits in a powerful way. By giving together during a short window, we unlock matching funds and create momentum that nonprofits rely on all year.</p>
                    <p class="about-three__text-2 editable">Qualifying nonprofit organizations in Teton Valley are invited to participate in the Tin Cup Challenge program and on Event Day. Through a unique match powered by Challengers, every gift, no matter the size, is amplified — turning shared participation into lasting impact for the valley we love.</p>
                    <a href="/nonprofits/" class="thm-btn about-three__btn">Browse Nonprofits</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQs Section -->
<section class="faqs-section" style="padding: 80px 0; background-color: var(--cftv-cream);">
    <div class="container">
        <div class="section-title text-center" style="margin-bottom: 50px;">
            <span class="section-title__tagline editable">Got Questions?</span>
            <h2 class="section-title__title editable">Frequently Asked Questions</h2>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="faq-page__single">
                    <div class="accrodion-grp faq-one-accrodion" data-grp-name="how-it-works-faq">
                        <div class="accrodion">
                            <div class="accrodion-title">
                                <h4 class="editable">Can I give to multiple nonprofits?</h4>
                            </div>
                            <div class="accrodion-content">
                                <div class="inner">
                                    <p class="editable">Yes! You can support as many participating nonprofits as you'd like with a single donation through Tin Cup.</p>
                                </div>
                            </div>
                        </div>
                        <div class="accrodion">
                            <div class="accrodion-title">
                                <h4 class="editable">Is my gift tax deductible?</h4>
                            </div>
                            <div class="accrodion-content">
                                <div class="inner">
                                    <p class="editable">Yes, all donations made through the Tin Cup Challenge are tax-deductible. You'll receive one consolidated tax receipt from the Community Foundation of Teton Valley.</p>
                                </div>
                            </div>
                        </div>
                        <div class="accrodion">
                            <div class="accrodion-title">
                                <h4 class="editable">What if I want to give by check?</h4>
                            </div>
                            <div class="accrodion-content">
                                <div class="inner">
                                    <p class="editable">Mail a check made payable to "Community Foundation of Teton Valley" along with a Donor Form outlining your distributions.</p>
                                </div>
                            </div>
                        </div>
                        <div class="accrodion">
                            <div class="accrodion-title">
                                <h4 class="editable">How does the match work?</h4>
                            </div>
                            <div class="accrodion-content">
                                <div class="inner">
                                    <p class="editable">Through the Challenger Fund, the Community Foundation of Teton Valley partially matches the first $25,000 each nonprofit raises during the Giving Period, helping strengthen organizations across every sector.</p>
                                </div>
                            </div>
                        </div>
                        <div class="accrodion last-chiled">
                            <div class="accrodion-title">
                                <h4 class="editable">When do nonprofits receive funds?</h4>
                            </div>
                            <div class="accrodion-content">
                                <div class="inner">
                                    <p class="editable">Nonprofits receive 100% of direct donations and a Match Grant at the Tin Cup Awards Party at the end of August.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

