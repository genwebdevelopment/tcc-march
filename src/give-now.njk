<!-- Give Options Section -->
<section class="give-options" style="padding: 80px 0;">
    <div class="container">
        <div class="row">
            <!-- Give to Nonprofits -->
            <div class="col-lg-6 mb-4">
                <div class="give-option-card" style="background: #fff; border-radius: 12px; padding: 40px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); height: 100%;">
                    <div class="give-option-icon" style="margin-bottom: 20px;">
                        <i class="fa fa-heart" style="font-size: 48px; color: var(--cftv-gold);"></i>
                    </div>
                    <h2 class="editable" style="font-family: 'Oswald', sans-serif; font-size: 32px; color: var(--cftv-navy); margin-bottom: 20px;">Give Directly to Nonprofits</h2>
                    <p class="editable" style="font-size: 18px; line-height: 1.6; margin-bottom: 30px;">Giving directly to nonprofits furthers critical missions. Nonprofits receive 100% of your donation.</p>
                    <a href="/nonprofits/" class="thm-btn" style="background: var(--cftv-gold); color: var(--cftv-navy);">Browse Nonprofits</a>
                </div>
            </div>

            <!-- Become a Challenger -->
            <div class="col-lg-6 mb-4">
                <div class="give-option-card" style="background: var(--cftv-navy); border-radius: 12px; padding: 40px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); height: 100%;">
                    <div class="give-option-icon" style="margin-bottom: 20px;">
                        <i class="fa fa-users" style="font-size: 48px; color: var(--cftv-gold);"></i>
                    </div>
                    <h2 class="editable" style="font-family: 'Oswald', sans-serif; font-size: 32px; color: #fff; margin-bottom: 20px;">Become a Challenger</h2>
                    <p class="editable" style="font-size: 18px; line-height: 1.6; margin-bottom: 30px; color: #ffffff;">Challengers help sustain the local nonprofit community by offering matching funds to all participating organizations during the Tin Cup Challenge, supporting Competitive Grants, funding Youth Philanthropy initiatives, and contributing to Nonprofit Resources like workshops at the Community Foundation of Teton Valley.</p>
                    <a href="/challengers/" class="thm-btn" style="background: var(--cftv-gold); color: var(--cftv-navy);">Learn More</a>
                </div>
            </div>
        </div>
    </div>
