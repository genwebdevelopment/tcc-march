<div class="give-now-page" style="background-color: #f9f6f1;">

<!--Page Header Start-->
<section class="page-header">
    <div class="page-header-bg" style="background-image: url(/assets/images/tin-cup/nonprofit-booths.jpg);">
    </div>
    <div class="container">
        <div class="page-header__inner">
            <ul class="thm-breadcrumb list-unstyled">
                <li><a href="/">Home</a></li>
                <li><span>/</span></li>
                <li class="active">Give Now</li>
            </ul>
            <h1 class="editable">Give Now</h1>
        </div>
    </div>
</section>
<!--Page Header End-->

<!-- Intro Section -->
<section class="page-intro" style="padding: 80px 0; background: var(--cftv-burgundy);">
    <div class="container">
        <div class="section-title text-center" style="margin-bottom: 0; padding-bottom: 0;">
            <h2 class="section-title__title editable" style="color: #fff;">Support Local Nonprofits</h2>
            <p class="editable" style="font-size: 24px; margin: 20px auto 0; color: #fff;">Give directly to nonprofits or become a Challenger to help match community donations.</p>
        </div>
    </div>
</section>

<!-- Give Options Section -->
<section class="give-options" style="padding: 80px 0;">
    <div class="container">
        <div class="row">
            <!-- Give to Nonprofits -->
            <div class="col-lg-6 mb-4">
                <div class="give-option-card" style="background: var(--cftv-navy); border-radius: 12px; padding: 40px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); height: 100%; display: flex; flex-direction: column;">
                    <div class="give-option-icon" style="margin-bottom: 20px;">
                        <i class="fa fa-heart" style="font-size: 48px; color: var(--cftv-gold);"></i>
                    </div>
                    <h2 class="editable" style="font-family: 'Oswald', sans-serif; font-size: 32px; color: #fff; margin-bottom: 20px;">Give Directly to Nonprofits</h2>
                    <p class="editable" style="font-size: 18px; line-height: 1.6; margin-bottom: 30px; color: #ffffff;">Giving directly to nonprofits furthers critical missions. Nonprofits receive 100% of your donation.</p>
                    <a href="/nonprofits/" class="thm-btn cta-banner__btn" style="margin-top: auto; align-self: flex-start;">Browse Nonprofits</a>
                </div>
            </div>

            <!-- Become a Challenger -->
            <div class="col-lg-6 mb-4">
                <div class="give-option-card" style="background: var(--cftv-navy); border-radius: 12px; padding: 40px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); height: 100%; display: flex; flex-direction: column;">
                    <div class="give-option-icon" style="margin-bottom: 20px;">
                        <i class="fa fa-users" style="font-size: 48px; color: var(--cftv-gold);"></i>
                    </div>
                    <h2 class="editable" style="font-family: 'Oswald', sans-serif; font-size: 32px; color: #fff; margin-bottom: 20px;">Become a Challenger</h2>
                    <p class="editable" style="font-size: 18px; line-height: 1.6; margin-bottom: 30px; color: #ffffff;">Challengers help sustain the local nonprofit community by offering matching funds to all participating organizations during the Tin Cup Challenge, supporting Competitive Grants, funding Youth Philanthropy initiatives, and contributing to Nonprofit Resources like workshops at the Community Foundation of Teton Valley.</p>
                    <a href="/challengers/" class="thm-btn cta-banner__btn" style="align-self: flex-start;">Learn More</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!--Nonprofit Banner Start-->
<section class="nonprofit-banner">
    <div class="container hero-container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <div class="nonprofit-banner__content">
                    <h3 class="nonprofit-banner__title editable">Are You a Nonprofit?</h3>
                    <p class="nonprofit-banner__text editable">Tin Cup is administered by the Community Foundation of Teton Valley. Visit our Tin Cup Challenge Program page for registration rules and important dates.</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="nonprofit-banner__btn-box">
                    <a href="https://cftetonvalley.org/tin-cup-challenge/" class="thm-btn nonprofit-banner__btn" target="_blank">Visit</a>
                </div>
            </div>
        </div>
    </div>
</section>
<!--Nonprofit Banner End-->

